<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardProgresoDiario"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <LinearLayout
            android:id="@+id/llDiarioStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <ImageView
                android:id="@+id/ivDiarioIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="6dp"
                android:src="@drawable/ic_power_full_b" />
            <TextView
                android:id="@+id/tvProgresoTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Progreso diario"
                android:textColor="@color/blue_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvProgresoPorcentaje"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="100%"
            android:textColor="@color/blue_primary"
            android:textSize="36sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/llDiarioStatus" />

        <FrameLayout
            android:id="@+id/flSemicircle"
            android:layout_width="140dp"
            android:layout_height="70dp"
            android:clipChildren="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ProgressBar
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:max="200"
                android:progress="100"
                android:progressDrawable="@drawable/circular_progress_background"
                android:rotation="180" />

            <ProgressBar
                android:id="@+id/pbProgresoDiario"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:max="200"
                android:progress="155"
                android:progressDrawable="@drawable/circular_progress_bar"
                android:rotation="180" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/llTopMonto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom"
            app:layout_constraintEnd_toEndOf="@id/flSemicircle"
            app:layout_constraintStart_toStartOf="@id/flSemicircle"
            app:layout_constraintBottom_toTopOf="@id/viewDivider">
            <TextView android:id="@+id/tvMontoActual" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="350" android:textColor="@color/blue_primary" android:textSize="28sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingBottom="4dp" android:text=" S/." android:textColor="@color/blue_dark" android:textSize="12sp" />
        </LinearLayout>

        <View
            android:id="@+id/viewDivider"
            android:layout_width="80dp"
            android:layout_height="2dp"
            android:background="@color/blue_divider"
            app:layout_constraintEnd_toEndOf="@id/flSemicircle"
            app:layout_constraintStart_toStartOf="@id/flSemicircle"
            app:layout_constraintTop_toBottomOf="@id/flSemicircle" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom"
            app:layout_constraintEnd_toEndOf="@id/flSemicircle"
            app:layout_constraintStart_toStartOf="@id/flSemicircle"
            app:layout_constraintTop_toBottomOf="@id/viewDivider">
            <TextView android:id="@+id/tvMontoObjetivo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="350" android:textColor="@color/blue_primary" android:textSize="14sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingBottom="2dp" android:text=" S/." android:textColor="@color/text_gray" android:textSize="10sp" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>