<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F0F2">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivUserPhoto"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_user_placeholder"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent" />

            <TextView
                android:id="@+id/tvSayHelloUser"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Buenos días,"
                android:textColor="#888888"
                android:textSize="12sp"
                app:layout_constraintBottom_toTopOf="@id/tvUserName"
                app:layout_constraintStart_toEndOf="@id/ivUserPhoto"
                app:layout_constraintTop_toTopOf="@id/ivUserPhoto"
                app:layout_constraintVertical_chainStyle="packed" />

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Jorge Ramirez"
                android:textColor="#2B558C"
                android:textSize="15sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/ivUserPhoto"
                app:layout_constraintStart_toEndOf="@id/ivUserPhoto"
                app:layout_constraintTop_toBottomOf="@id/tvSayHelloUser" />

            <ImageView
                android:id="@+id/ivMenu"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_menu"
                app:layout_constraintBottom_toBottomOf="@id/ivUserPhoto"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/ivUserPhoto"
                app:tint="#2B558C" />

            <TextView
                android:id="@+id/tvMetasTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Resumen de metas establecidas"
                android:textColor="#555555"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/ivUserPhoto" />

            <LinearLayout
                android:id="@+id/llMetasContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:weightSum="3"
                app:layout_constraintTop_toBottomOf="@id/tvMetasTitle">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="50dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="horizontal" android:paddingVertical="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Diario: " android:textColor="#000000" android:textSize="11sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="S/ " android:textColor="#000000" android:alpha="0.6" android:textSize="11sp" />
                        <TextView android:id="@+id/tvMetaDiaria" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="350" android:textColor="@color/black" android:textSize="12sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="50dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="horizontal" android:paddingVertical="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sem: " android:textColor="#000000" android:textSize="11sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="S/ " android:textColor="#000000" android:alpha="0.6" android:textSize="11sp" />
                        <TextView android:id="@+id/tvMetaSemanal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2450" android:textColor="#000000" android:textSize="12sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="50dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="horizontal" android:paddingVertical="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mens: " android:textColor="#000000" android:textSize="11sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="S/ " android:textColor="#000000" android:alpha="0.6" android:textSize="11sp" />
                        <TextView android:id="@+id/tvMetaMensual" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="7500" android:textColor="@color/black" android:textSize="12sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProgresoDiario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toBottomOf="@id/llMetasContainer"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <LinearLayout
                        android:id="@+id/llDiarioStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">
                        <ImageView
                            android:id="@+id/ivDiarioIcon"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="6dp"
                            android:src="@drawable/ic_power_full_b" />
                        <TextView
                            android:id="@+id/tvProgresoTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Progreso diario"
                            android:textColor="#4579BC"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvProgresoPorcentaje"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="100%"
                        android:textColor="#4579BC"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/llDiarioStatus" />

                    <FrameLayout
                        android:id="@+id/flSemicircle"
                        android:layout_width="140dp"
                        android:layout_height="70dp"
                        android:clipChildren="true"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ProgressBar
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="140dp"
                            android:layout_height="140dp"
                            android:max="200"
                            android:progress="100"
                            android:progressDrawable="@drawable/circular_progress_background"
                            android:rotation="180" />

                        <ProgressBar
                            android:id="@+id/pbProgresoDiario"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="140dp"
                            android:layout_height="140dp"
                            android:max="200"
                            android:progress="155"
                            android:progressDrawable="@drawable/circular_progress_bar"
                            android:rotation="180" />
                    </FrameLayout>

                    <LinearLayout
                        android:id="@+id/llTopMonto"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="bottom"
                        app:layout_constraintEnd_toEndOf="@id/flSemicircle"
                        app:layout_constraintStart_toStartOf="@id/flSemicircle"
                        app:layout_constraintBottom_toTopOf="@id/viewDivider">
                        <TextView android:id="@+id/tvMontoActual" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="350" android:textColor="#4579BC" android:textSize="28sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingBottom="4dp" android:text=" S/." android:textColor="#2B558C" android:textSize="12sp" />
                    </LinearLayout>

                    <View
                        android:id="@+id/viewDivider"
                        android:layout_width="80dp"
                        android:layout_height="2dp"
                        android:background="#A0C3D9"
                        app:layout_constraintEnd_toEndOf="@id/flSemicircle"
                        app:layout_constraintStart_toStartOf="@id/flSemicircle"
                        app:layout_constraintTop_toBottomOf="@id/flSemicircle" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="bottom"
                        app:layout_constraintEnd_toEndOf="@id/flSemicircle"
                        app:layout_constraintStart_toStartOf="@id/flSemicircle"
                        app:layout_constraintTop_toBottomOf="@id/viewDivider">
                        <TextView android:id="@+id/tvMontoObjetivo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="350" android:textColor="#4579BC" android:textSize="14sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingBottom="2dp" android:text=" S/." android:textColor="#888888" android:textSize="10sp" />
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProgresoSemanal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="#4579BC"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toBottomOf="@id/cardProgresoDiario"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <LinearLayout
                        android:id="@+id/llSemanalStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">
                        <ImageView
                            android:id="@+id/ivSemanalIcon"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginEnd="6dp"
                            android:src="@drawable/ic_power_full_w" />
                        <TextView
                            android:id="@+id/tvSemanalStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Excelente"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvSemanalTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginEnd="12dp"
                        android:text="Tu progreso\nsemanal"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/flSemanalChart"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/llSemanalStatus" />

                    <FrameLayout
                        android:id="@+id/flSemanalChart"
                        android:layout_width="85dp"
                        android:layout_height="85dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ProgressBar
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:max="100"
                            android:progress="100"
                            android:progressDrawable="@drawable/circular_progress_full_bg" />

                        <ProgressBar
                            android:id="@+id/pbProgresoSemanal"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:max="100"
                            android:progress="100"
                            android:progressDrawable="@drawable/circular_progress_full_bar" />

                        <TextView
                            android:id="@+id/tvSemanalPorcentaje"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="100%"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDineroAcumulado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toBottomOf="@id/cardProgresoSemanal"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvDineroAcumuladoTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dinero acumulado"
                        android:textColor="#222222"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        app:layout_constraintBottom_toBottomOf="@id/tvDineroAcumuladoTitle"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Objetivo: " android:textColor="#888888" android:textSize="11sp" />
                        <TextView android:id="@+id/tvDineroObjetivo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="7000" android:textColor="#222222" android:textSize="12sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" Soles" android:textColor="#888888" android:textSize="9sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/llMontoAcumulado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:gravity="bottom"
                        android:orientation="horizontal"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvDineroAcumuladoTitle">
                        <TextView android:id="@+id/tvDineroTotal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1750" android:textColor="#222222" android:textSize="24sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:alpha="0.6" android:paddingBottom="4dp" android:text=" Soles" android:textColor="#000000" android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/llChartBars"
                        android:layout_width="match_parent"
                        android:layout_height="110dp"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal"
                        android:weightSum="7"
                        app:layout_constraintTop_toBottomOf="@id/llMontoAcumulado">

                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="bottom|center_horizontal" android:orientation="horizontal">
                                <View android:id="@+id/barEgresoLu" android:layout_width="8dp" android:layout_height="70dp" android:background="@drawable/bg_bar_grey" />
                                <Space android:layout_width="4dp" android:layout_height="wrap_content" />
                                <View android:id="@+id/barIngresoLu" android:layout_width="8dp" android:layout_height="90dp" android:background="@drawable/bg_bar_blue" />
                            </LinearLayout>
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:gravity="center" android:text="Lu" android:textColor="#888888" android:textSize="10sp" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="bottom|center_horizontal" android:orientation="horizontal">
                                <View android:id="@+id/barEgresoMar" android:layout_width="8dp" android:layout_height="40dp" android:background="@drawable/bg_bar_grey" />
                                <Space android:layout_width="4dp" android:layout_height="wrap_content" />
                                <View android:id="@+id/barIngresoMar" android:layout_width="8dp" android:layout_height="75dp" android:background="@drawable/bg_bar_blue" />
                            </LinearLayout>
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:gravity="center" android:text="Mar" android:textColor="#888888" android:textSize="10sp" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="bottom|center_horizontal" android:orientation="horizontal">
                                <View android:id="@+id/barEgresoMie" android:layout_width="8dp" android:layout_height="50dp" android:background="@drawable/bg_bar_grey" />
                                <Space android:layout_width="4dp" android:layout_height="wrap_content" />
                                <View android:id="@+id/barIngresoMie" android:layout_width="8dp" android:layout_height="85dp" android:background="@drawable/bg_bar_blue" />
                            </LinearLayout>
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:gravity="center" android:text="Mie" android:textColor="#888888" android:textSize="10sp" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="bottom|center_horizontal" android:orientation="horizontal">
                                <View android:id="@+id/barEgresoJue" android:layout_width="8dp" android:layout_height="75dp" android:background="@drawable/bg_bar_grey" />
                                <Space android:layout_width="4dp" android:layout_height="wrap_content" />
                                <View android:id="@+id/barIngresoJue" android:layout_width="8dp" android:layout_height="65dp" android:background="@drawable/bg_bar_blue" />
                            </LinearLayout>
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:gravity="center" android:text="Jue" android:textColor="#888888" android:textSize="10sp" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="bottom|center_horizontal" android:orientation="horizontal">
                                <View android:id="@+id/barEgresoVie" android:layout_width="8dp" android:layout_height="45dp" android:background="@drawable/bg_bar_grey" />
                                <Space android:layout_width="4dp" android:layout_height="wrap_content" />
                                <View android:id="@+id/barIngresoVie" android:layout_width="8dp" android:layout_height="70dp" android:background="@drawable/bg_bar_blue" />
                            </LinearLayout>
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:gravity="center" android:text="Vie" android:textColor="#888888" android:textSize="10sp" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="bottom|center_horizontal" android:orientation="horizontal">
                                <View android:id="@+id/barEgresoSab" android:layout_width="8dp" android:layout_height="35dp" android:background="@drawable/bg_bar_grey" />
                                <Space android:layout_width="4dp" android:layout_height="wrap_content" />
                                <View android:id="@+id/barIngresoSab" android:layout_width="8dp" android:layout_height="55dp" android:background="@drawable/bg_bar_blue" />
                            </LinearLayout>
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:gravity="center" android:text="Sab" android:textColor="#888888" android:textSize="10sp" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:gravity="bottom|center_horizontal" android:orientation="horizontal">
                                <View android:id="@+id/barEgresoDom" android:layout_width="8dp" android:layout_height="60dp" android:background="@drawable/bg_bar_grey" />
                                <Space android:layout_width="4dp" android:layout_height="wrap_content" />
                                <View android:id="@+id/barIngresoDom" android:layout_width="8dp" android:layout_height="50dp" android:background="@drawable/bg_bar_blue" />
                            </LinearLayout>
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:gravity="center" android:text="Dom" android:textColor="#888888" android:textSize="10sp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomNavCard"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <ImageView android:id="@+id/navHome" android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:src="@drawable/ic_home" />
            <ImageView android:id="@+id/navCalendar" android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:src="@drawable/ic_calendar" />

            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.2" />

            <ImageView android:id="@+id/navStats" android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:src="@drawable/ic_stats" />
            <ImageView android:id="@+id/navUser" android:layout_width="0dp" android:layout_height="30dp" android:layout_weight="1" android:src="@drawable/ic_user" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <FrameLayout
        android:layout_width="80dp"
        android:layout_height="80dp"
        app:layout_anchor="@id/bottomNavCard"
        app:layout_anchorGravity="top|center"
        android:translationY="-10dp"
        android:elevation="10dp"> <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardBackgroundColor="#F0F0F2"
        app:cardCornerRadius="34dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFabAdd"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="center"
            app:cardBackgroundColor="#4579BC"
            app:cardCornerRadius="27dp"
            app:cardElevation="4dp"
            app:strokeWidth="0dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_add"
                app:tint="#FFFFFF" />
        </com.google.android.material.card.MaterialCardView>
    </com.google.android.material.card.MaterialCardView>
    </FrameLayout>

